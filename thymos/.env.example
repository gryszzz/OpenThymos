# Thymos Server Configuration
# Copy this to .env and fill in your values.

# ── Cognition Providers ───────────────────────────────────────────────────────
# Set at least one to enable LLM-driven cognition (otherwise mock is used).
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Server ────────────────────────────────────────────────────────────────────
# THYMOS_RUNTIME_MODE=reference
# THYMOS_LEDGER_PATH=thymos-ledger.db
# THYMOS_POSTGRES_URL=postgres://thymos:thymos@localhost:5432/thymos
# THYMOS_DB_PATH=thymos-runs.db
# THYMOS_GATEWAY_DB_PATH=thymos-gateway.db
# THYMOS_MARKETPLACE_DB_PATH=thymos-marketplace.db
# THYMOS_TOOL_FABRIC=in_process
# THYMOS_WORKER_BIN=/absolute/path/to/target/debug/thymos-worker

# ── API Gateway (optional) ────────────────────────────────────────────────────
# Comma-separated: key:tenant_id:name:rate_limit_rpm
# THYMOS_API_KEYS=sk-test-1:tenant-a:dev-key:60

# ── JWT Auth (optional) ──────────────────────────────────────────────────────
# THYMOS_JWT_SECRET=your-hmac-secret-at-least-32-bytes
# THYMOS_JWT_ISSUER=https://your-auth-provider.com
# THYMOS_JWT_AUDIENCE=thymos

# ── Observability (optional) ─────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# RUST_LOG=info
